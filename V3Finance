function computeSSS(s){const sal=Math.min(Math.max(s,4250),29750);const st=Math.round((sal-4250)/500);return Math.min(Math.round((180+st*22.5)*100)/100,1350);}
function computePhilHealth(s){return Math.round(Math.min(Math.max(s,10000),100000)*0.025*100)/100;}
function computeHDMF(s){if(s<=1500)return Math.round(s*0.01*100)/100;return Math.min(Math.round(s*0.02*100)/100,200);}
function computeWHT(s){
  const sss=computeSSS(s),phic=computePhilHealth(s),hdmf=computeHDMF(s),tx=s-sss-phic-hdmf;
  let tax=0;
  if(tx>666667)tax=200833+(tx-666667)*0.35;
  else if(tx>166667)tax=40833+(tx-166667)*0.32;
  else if(tx>66667)tax=10833+(tx-66667)*0.30;
  else if(tx>33333)tax=2500+(tx-33333)*0.25;
  else if(tx>20833)tax=(tx-20833)*0.20;
  return{sss,phic,hdmf,tax:Math.round(tax*100)/100,taxable:tx,net:Math.round((tx-tax)*100)/100};
}

