          {/* ═══ TRANSACTIONS ═══ */}
          {tab==="transactions"&&(
            <div>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20}}>
                <h2 style={{fontFamily:"Plus Jakarta Sans",fontWeight:800,fontSize:22}}>Transactions</h2>
                <div style={{display:"flex",gap:8}}>
                  <Btn onClick={()=>setModal("income")}>+ Income</Btn>
                  <Btn variant="amber" onClick={()=>setModal("expense")}>+ Expense</Btn>
                </div>
              </div>

              <div style={{fontSize:11,color:"#7A6E5C",fontWeight:700,textTransform:"uppercase",letterSpacing:".06em",marginBottom:9}}>Income</div>
              {income.map(i=>(
                <div key={i.id} style={{...card({padding:"12px 16px",marginBottom:8}),display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                  <div style={{display:"flex",alignItems:"center",gap:11}}>
                    <div style={{width:34,height:34,borderRadius:9,background:"#00956A20",display:"flex",alignItems:"center",justifyContent:"center",fontSize:17}}>
                      {ITYPES.find(t=>t.v===i.type)?.l.split(" ")[0]||"💼"}
                    </div>
                    <div>
                      <div style={{fontWeight:600,fontSize:13}}>{i.desc}</div>
                      <div style={{fontSize:11,color:"#7A6E5C"}}>{i.date} · {i.earner} · {i.via}</div>
                    </div>
                  </div>
                  <div style={{display:"flex",alignItems:"center",gap:10}}>
                    <span style={{fontFamily:"Plus Jakarta Sans",fontWeight:700,fontSize:15,color:"#00956A"}}>+{peso(i.amount)}</span>
                    <button onClick={()=>setIncome(x=>x.filter(e=>e.id!==i.id))} style={{background:"none",border:"none",color:"#C4BDAF",cursor:"pointer",fontSize:18,lineHeight:1}}>×</button>
                  </div>
                </div>
              ))}

              <div style={{fontSize:11,color:"#7A6E5C",fontWeight:700,textTransform:"uppercase",letterSpacing:".06em",margin:"18px 0 9px"}}>Expenses</div>
              {expenses.map(e=>{
                const info=ci(e.cat);
                return(
                  <div key={e.id} style={{...card({padding:"12px 16px",marginBottom:8}),display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                    <div style={{display:"flex",alignItems:"center",gap:11}}>
                      <div style={{width:34,height:34,borderRadius:9,background:(CC[e.cat]||"#505050")+"20",display:"flex",alignItems:"center",justifyContent:"center",fontSize:17}}>{info.i}</div>
                      <div>
                        <div style={{fontWeight:600,fontSize:13}}>{e.desc}</div>
                        <div style={{fontSize:11,color:"#7A6E5C"}}>{e.date} · {e.earner} · {e.via}</div>
                      </div>
                    </div>
                    <div style={{display:"flex",alignItems:"center",gap:9}}>
                      <Tag color={CC[e.cat]||"#505050"}>{info.l}</Tag>
                      <span style={{fontFamily:"Plus Jakarta Sans",fontWeight:700,fontSize:15,color:"#D44040"}}>−{peso(e.amount)}</span>
                      <button onClick={()=>delExpense(e.id)} style={{background:"none",border:"none",color:"#C4BDAF",cursor:"pointer",fontSize:18,lineHeight:1}}>×</button>
                    </div>
                  </div>
                );
              })}
            </div>
          )}

          {/* ═══ BILLS ═══ */}
          {tab==="bills"&&(
            <div>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
                <h2 style={{fontFamily:"Plus Jakarta Sans",fontWeight:800,fontSize:22}}>Monthly Bills</h2>
                <Btn onClick={()=>setModal("bill")}>+ Add Bill</Btn>
              </div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(150px,1fr))",gap:12,marginBottom:18}}>
                {[
                  {label:"Total",val:peso(totalBills),color:"#2A2218"},
                  {label:"Paid",val:peso(paidBills),color:"#00956A"},
                  {label:"Unpaid",val:peso(unpaidBills),color:"#D44040"},
                  {label:"Progress",val:`${bills.filter(b=>b.paid).length} / ${bills.length}`,color:"#5A5FE0"},
                ].map(k=>(
                  <div key={k.label} style={card()}>
                    <div style={{fontSize:10,color:"#7A6E5C",textTransform:"uppercase",letterSpacing:".06em",marginBottom:6}}>{k.label}</div>
                    <div style={{fontFamily:"Plus Jakarta Sans",fontWeight:800,fontSize:21,color:k.color}}>{k.val}</div>
                  </div>
                ))}
              </div>
              {bills.map(b=>{
                const info=ci(b.cat);
                return(
                  <div key={b.id} style={{...card({padding:"13px 18px",marginBottom:9}),display:"flex",justifyContent:"space-between",alignItems:"center",opacity:b.paid?.7:1}}>
                    <div style={{display:"flex",alignItems:"center",gap:11}}>
                      <button onClick={()=>toggleBill(b.id)} style={{width:24,height:24,borderRadius:6,border:`2px solid ${b.paid?"#00956A":"#C4BDAF"}`,background:b.paid?"#00956A":"transparent",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}>
                        {b.paid&&<span style={{color:"#fff",fontSize:11,fontWeight:700}}>✓</span>}
                      </button>
                      <div style={{width:32,height:32,borderRadius:8,background:(CC[b.cat]||"#505050")+"20",display:"flex",alignItems:"center",justifyContent:"center",fontSize:15}}>{info.i}</div>
                      <div>
                        <div style={{fontWeight:600,fontSize:14,textDecoration:b.paid?"line-through":"none",color:b.paid?"#9E9282":"#2A2218"}}>{b.name}</div>
                        <div style={{fontSize:11,color:"#7A6E5C"}}>Due Jun {b.dueDay}</div>
                      </div>
                    </div>
                    <div style={{display:"flex",alignItems:"center",gap:9}}>
                      <span style={{fontFamily:"Plus Jakarta Sans",fontWeight:700,fontSize:15,color:b.paid?"#00956A":"#C07A00"}}>{peso(b.amount)}</span>
                      <Tag color={b.paid?"#00956A":"#C07A00"}>{b.paid?"Paid":"Unpaid"}</Tag>
                      <button onClick={()=>setBills(x=>x.filter(x2=>x2.id!==b.id))} style={{background:"none",border:"none",color:"#C4BDAF",cursor:"pointer",fontSize:18,lineHeight:1}}>×</button>
                    </div>
                  </div>
                );
              })}
            </div>
          )}

          {/* ═══ CREDIT CARDS ═══ */}
          {tab==="credit"&&(
            <div>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:20}}>
                <h2 style={{fontFamily:"Plus Jakarta Sans",fontWeight:800,fontSize:22}}>Credit Cards</h2>
                <Btn onClick={()=>setModal("card")}>+ Add Card</Btn>
              </div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(290px,1fr))",gap:16}}>
                {cards.map(c=>{
                  const thisMonth=ccCharges[c.id]||0;
                  const total=c.outstandingBalance;
                  const avail=Math.max(0,c.limit-total);
                  const pct=Math.min(100,total/c.limit*100);
                  const minDue=Math.max(total*0.03,500);
                  return(
                    <div key={c.id} style={card({padding:0,overflow:"hidden"})}>
                      <div style={{background:`linear-gradient(135deg,${c.color}DD,${c.color}99)`,padding:"18px 22px",color:"#fff"}}>
                        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
                          <div>
                            <div style={{fontSize:10,opacity:.75,letterSpacing:".08em",textTransform:"uppercase",marginBottom:3}}>{c.bank}</div>
                            <div style={{fontFamily:"Plus Jakarta Sans",fontWeight:700,fontSize:17}}>{c.name}</div>
                          </div>
                          <div style={{textAlign:"right"}}>
                            <div style={{fontSize:10,opacity:.75,marginBottom:2}}>Limit</div>
                            <div style={{fontFamily:"Plus Jakarta Sans",fontWeight:700,fontSize:15}}>{peso(c.limit)}</div>
                          </div>
                        </div>
                        <div style={{marginTop:16}}>
                          <div style={{display:"flex",justifyContent:"space-between",marginBottom:5}}>
                            <span style={{fontSize:11,opacity:.75}}>Used: {peso(total)}</span>
                            <span style={{fontSize:11,opacity:.75}}>Avail: {peso(avail)}</span>
                          </div>
                          <div style={{height:5,background:"rgba(255,255,255,.25)",borderRadius:5}}>
                            <div style={{height:5,borderRadius:5,background:"rgba(255,255,255,.85)",width:pct+"%",transition:"width 1s"}}/>
                          </div>
                        </div>
                      </div>
                      <div style={{padding:"14px 22px"}}>
                        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10}}>
                          {[
                            {label:"Statement",val:peso(c.statementBalance)},
                            {label:"This Month",val:peso(thisMonth),color:"#C07A00"},
                            {label:"Min. Due",val:peso(minDue,2),color:"#D44040"},
                          ].map(k=>(
                            <div key={k.label}>
                              <div style={{fontSize:10,color:"#7A6E5C",marginBottom:3}}>{k.label}</div>
                              <div style={{fontWeight:700,fontSize:13,color:k.color||"#2A2218"}}>{k.val}</div>
                            </div>
                          ))}
                        </div>
                        <div style={{display:"flex",justifyContent:"space-between",marginTop:11,paddingTop:11,borderTop:"1px solid #E8E2D8",fontSize:11,color:"#7A6E5C"}}>
                          <span>Cut-off: Day {c.cutDay}</span>
                          <span>Due: Day {c.dueDay}</span>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          {/* ═══ BUDGET ═══ */}
          {tab==="budget"&&(
            <div>
              <h2 style={{fontFamily:"Plus Jakarta Sans",fontWeight:800,fontSize:22,marginBottom:4}}>Budget Tracker</h2>
              <p style={{color:"#7A6E5C",fontSize:13,marginBottom:18}}>Tap a card to edit the budget for that category.</p>
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(155px,1fr))",gap:13}}>
                {Object.entries(budgets).map(([cat,budget])=>{
                  const spent=spendByCat[cat]||0;
                  const pct=budget>0?spent/budget*100:0;
                  const info=ci(cat);
                  return(
                    <div key={cat} style={{...card({padding:"18px 16px"}),textAlign:"center",cursor:"pointer"}} onClick={()=>{setModal("editBudget");setForm({cat,budget});}}>
                      <div style={{position:"relative",width:76,height:76,margin:"0 auto 11px",display:"flex",alignItems:"center",justifyContent:"center"}}>
                        <Ring pct={pct} color={CC[cat]||"#505050"}/>
                        <div style={{position:"absolute",fontSize:22}}>{info.i}</div>
                      </div>
                      <div style={{fontWeight:600,fontSize:12,marginBottom:2}}>{info.l}</div>
                      <div style={{fontSize:11,color:pct>100?"#D44040":"#7A6E5C"}}>{peso(spent)} / {peso(budget)}</div>
                      <div style={{fontSize:10,color:pct>100?"#D44040":"#00956A",fontWeight:700,marginTop:2}}>{Math.round(pct)}%</div>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          {/* ═══ INCOME ANALYSIS ═══ */}
          {tab==="analysis"&&(
            <div>
              <h2 style={{fontFamily:"Plus Jakarta Sans",fontWeight:800,fontSize:22,marginBottom:4}}>Income Analysis</h2>
              <p style={{color:"#7A6E5C",fontSize:13,marginBottom:18}}>PH government deductions — SSS, PhilHealth, Pag-IBIG, WHT</p>

              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16,marginBottom:18}}>
                {[
                  {name:"You",salary:salaries.you,ded:dedYou,key:"you"},
                  {name:"Partner",salary:salaries.partner,ded:dedPart,key:"partner"},
                ].map(p=>(
                  <div key={p.key} style={card()}>
                    <div style={{fontWeight:700,fontSize:15,marginBottom:14}}>👤 {p.name}</div>
                    <Inp label="Monthly Gross (₱)" type="number" value={salaries[p.key]} onChange={e=>setSalaries(x=>({...x,[p.key]:+e.target.value}))}/>
                    {[
                      {label:"SSS",val:p.ded.sss,color:"#5A5FE0"},
                      {label:"PhilHealth",val:p.ded.phic,color:"#00956A"},
                      {label:"Pag-IBIG",val:p.ded.hdmf,color:"#C07A00"},
                      {label:"Withholding Tax",val:p.ded.tax,color:"#D44040"},
                    ].map(d=>(
                      <div key={d.label} style={{display:"flex",justifyContent:"space-between",padding:"7px 0",borderBottom:"1px solid #E8E2D8"}}>
                        <span style={{fontSize:13}}>{d.label}</span>
                        <span style={{fontWeight:700,fontSize:13,color:d.color}}>−{peso(d.val,2)}</span>
                      </div>
                    ))}
                    <div style={{display:"flex",justifyContent:"space-between",padding:"10px 0 0",marginTop:4}}>
                      <span style={{fontWeight:700}}>Net Take-Home</span>
                      <span style={{fontFamily:"Plus Jakarta Sans",fontWeight:800,fontSize:16,color:"#00956A"}}>{peso(p.ded.net,2)}</span>
                    </div>
                  </div>
                ))}
              </div>

              <div style={card({padding:"20px 24px"})}>
                <div style={{fontWeight:700,fontSize:15,marginBottom:15}}>🏠 Household Combined</div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:13}}>
                  {[
                    {label:"Combined Gross",val:peso(salaries.you+salaries.partner),color:"#2A2218"},
                    {label:"Total Deductions",val:peso(totalDed),color:"#D44040"},
                    {label:"Combined Net",val:peso(combinedNet),color:"#00956A"},
                  ].map(k=>(
                    <div key={k.label} style={{background:"#EDE5D8",borderRadius:10,padding:"13px 15px",border:"1px solid #D0C8BA"}}>
                      <div style={{fontSize:10,color:"#7A6E5C",textTransform:"uppercase",letterSpacing:".05em",marginBottom:5}}>{k.label}</div>
                      <div style={{fontFamily:"Plus Jakarta Sans",fontWeight:800,fontSize:19,color:k.color}}>{k.val}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

        </main>
      </div>

      {/* ── MODALS ── */}
      {modal==="income"&&(
        <Modal title="Add Income" onClose={closeModal}>
          <Inp label="Description" value={form.desc||""} onChange={e=>ff("desc",e.target.value)} placeholder="e.g. Monthly Salary"/>
          <Inp label="Amount (₱)" type="number" value={form.amount||""} onChange={e=>ff("amount",e.target.value)} placeholder="0"/>
          <Inp label="Date" type="date" value={form.date||todayStr()} onChange={e=>ff("date",e.target.value)}/>
          <Sel label="Type" value={form.type||"salary"} onChange={e=>ff("type",e.target.value)}>
            {ITYPES.map(t=><option key={t.v} value={t.v}>{t.l}</option>)}
          </Sel>
          <Sel label="Earner" value={form.earner||"You"} onChange={e=>ff("earner",e.target.value)}>
            <option>You</option><option>Partner</option><option>Joint</option>
          </Sel>
          <Sel label="Via" value={form.via||"Bank Transfer"} onChange={e=>ff("via",e.target.value)}>
            {PAY.map(m=><option key={m}>{m}</option>)}
          </Sel>
          <div style={{display:"flex",gap:8,marginTop:6}}>
            <Btn onClick={addIncome} style={{flex:1}}>Add Income</Btn>
            <Btn variant="ghost" onClick={closeModal}>Cancel</Btn>
          </div>
        </Modal>
      )}

      {modal==="expense"&&(
        <Modal title="Add Expense" onClose={closeModal}>
          <Inp label="Description" value={form.desc||""} onChange={e=>ff("desc",e.target.value)} placeholder="e.g. Grab Ride"/>
          <Inp label="Amount (₱)" type="number" value={form.amount||""} onChange={e=>ff("amount",e.target.value)} placeholder="0"/>
          <Inp label="Date" type="date" value={form.date||todayStr()} onChange={e=>ff("date",e.target.value)}/>
          <Sel label="Category" value={form.cat||"other"} onChange={e=>ff("cat",e.target.value)}>
            {CATS.map(c=><option key={c.v} value={c.v}>{c.i} {c.l}</option>)}
          </Sel>
          <Sel label="Paid Via" value={form.via||"Cash"} onChange={e=>ff("via",e.target.value)}>
            {PAY.map(m=><option key={m}>{m}</option>)}
            {cards.map(c=><option key={c.id}>{c.name}</option>)}
          </Sel>
          <Sel label="Earner" value={form.earner||"You"} onChange={e=>ff("earner",e.target.value)}>
            <option>You</option><option>Partner</option><option>Joint</option>
          </Sel>
          <div style={{display:"flex",gap:8,marginTop:6}}>
            <Btn variant="amber" onClick={addExpense} style={{flex:1}}>Add Expense</Btn>
            <Btn variant="ghost" onClick={closeModal}>Cancel</Btn>
          </div>
        </Modal>
      )}

      {modal==="bill"&&(
        <Modal title="Add Bill" onClose={closeModal}>
          <Inp label="Bill Name" value={form.name||""} onChange={e=>ff("name",e.target.value)} placeholder="e.g. Meralco"/>
          <Inp label="Amount (₱)" type="number" value={form.amount||""} onChange={e=>ff("amount",e.target.value)} placeholder="0"/>
          <Inp label="Due Day (of month)" type="number" value={form.dueDay||""} onChange={e=>ff("dueDay",e.target.value)} placeholder="15"/>
          <Sel label="Category" value={form.cat||"utilities"} onChange={e=>ff("cat",e.target.value)}>
            {CATS.map(c=><option key={c.v} value={c.v}>{c.i} {c.l}</option>)}
          </Sel>
          <div style={{display:"flex",gap:8,marginTop:6}}>
            <Btn onClick={addBill} style={{flex:1}}>Add Bill</Btn>
            <Btn variant="ghost" onClick={closeModal}>Cancel</Btn>
          </div>
        </Modal>
      )}

      {modal==="card"&&(
        <Modal title="Add Credit Card" onClose={closeModal}>
          <Inp label="Card Name" value={form.name||""} onChange={e=>ff("name",e.target.value)} placeholder="e.g. BPI Gold"/>
          <Inp label="Bank" value={form.bank||""} onChange={e=>ff("bank",e.target.value)} placeholder="e.g. BPI"/>
          <Inp label="Credit Limit (₱)" type="number" value={form.limit||""} onChange={e=>ff("limit",e.target.value)} placeholder="50000"/>
          <Inp label="Statement Balance (₱)" type="number" value={form.stmtBal||""} onChange={e=>ff("stmtBal",e.target.value)} placeholder="0"/>
          <Inp label="Cut-off Day" type="number" value={form.cutDay||""} onChange={e=>ff("cutDay",e.target.value)} placeholder="25"/>
          <Inp label="Due Day" type="number" value={form.dueDay||""} onChange={e=>ff("dueDay",e.target.value)} placeholder="20"/>
          <div style={{display:"flex",gap:8,marginTop:6}}>
            <Btn onClick={addCard} style={{flex:1}}>Add Card</Btn>
            <Btn variant="ghost" onClick={closeModal}>Cancel</Btn>
          </div>
        </Modal>
      )}

      {modal==="editBudget"&&(
        <Modal title={`Edit Budget — ${ci(form.cat)?.l}`} onClose={closeModal}>
          <Inp label="Monthly Budget (₱)" type="number" value={form.budget||""} onChange={e=>ff("budget",e.target.value)} placeholder="0"/>
          <div style={{display:"flex",gap:8,marginTop:6}}>
            <Btn onClick={()=>{setBudgets(x=>({...x,[form.cat]:+form.budget}));closeModal();}} style={{flex:1}}>Save</Btn>
            <Btn variant="ghost" onClick={closeModal}>Cancel</Btn>
          </div>
        </Modal>
      )}
    </>
  );
}
